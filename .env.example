GOOGLE_MAPS_API_KEY=your_google_key_here
GOOGLE_GEOCODING_BASE_URL=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_PLACES_NEARBY_BASE_URL=https://places.googleapis.com/v1/places:searchNearby
GOOGLE_PLACES_AUTOCOMPLETE_BASE_URL=https://places.googleapis.com/v1/places:autocomplete

# Flask
# SECRET_KEY is required in production (FLASK_ENV=production) - the app
# refuses to start without it, since a blank key silently disables
# session/CSRF protection.
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=change_me_to_a_long_random_value

# Which provider implementation backs each capability (see providers/registry.py).
# Change one of these + add a new adapter class to swap an external API
# without touching services/, ranking/, or Flask routes.
MARINE_PROVIDER=open_meteo
FORECAST_PROVIDER=open_meteo
GEOCODING_PROVIDER=google
PLACES_PROVIDER=google

# Which scoring model to use (see ranking/factory.py).
RANKING_STRATEGY=classic

# Caching
CACHE_PATH=.cache/surfspot_cache.json
CACHE_TTL_SECONDS=600

# Rate limiting (Flask-Limiter). Use redis://... for RATELIMIT_STORAGE_URI
# once running more than one worker process.
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=60 per minute
RATE_LIMIT_SEARCH=20 per minute
RATE_LIMIT_AUTOCOMPLETE=30 per minute
